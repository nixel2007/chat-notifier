// Генераторы совета мастера для изолированных интеграционных тестов.
// Детальки - вложенные объекты (как в autumn-properties.json): PROXY.LOGIN,
// PROXY.TOKEN и TELEGRAM.BOT.TOKEN. Токен бота фиктивный: боевой транспорт
// замокан (&Верховный ДубМокаМессенджера), Telegram не вызывается.

#Использовать autumn

// Совет с деталями авторизации прокси и фиктивным токеном бота.
//
// Возвращаемое значение:
//   СоветДругогоМастера - настройки создания поделки со значениями деталек.
Функция СоветСДеталями() Экспорт

	Прокси = Новый Соответствие();
	Прокси.Вставить("LOGIN", "api");
	Прокси.Вставить("TOKEN", "s3cr3t");

	Бот = Новый Соответствие();
	Бот.Вставить("TOKEN", "фиктивный-токен");
	Телеграм = Новый Соответствие();
	Телеграм.Вставить("BOT", Бот);

	Детальки = Новый Соответствие();
	Детальки.Вставить("PROXY", Прокси);
	Детальки.Вставить("TELEGRAM", Телеграм);

	СоветДругогоМастера = Новый СоветДругогоМастера();
	СоветДругогоМастера.ЗначенияДеталек(Детальки);

	Возврат СоветДругогоМастера;

КонецФункции
