#Использовать ".."
#Использовать "."
#Использовать autumn
#Использовать autumn-validate
#Использовать winow
#Использовать 1connector
#Использовать asserts

// Интеграционные тесты: поднимают полный контейнер ОСени с веб-сервером winow
// и дёргают реальные HTTP-эндпоинты через 1connector.
//
// Детальки авторизации и токен бота задаются советом мастера
// (ГенераторСоветов.СоветСДеталями), поэтому тесты не зависят от переменных
// окружения. Боевой транспорт заменён моком (ДубМокаМессенджера, &Верховный) из
// tests/Классы; и мок, и генератор совета подключаются через #Использовать ".".
// Поэтому Telegram не вызывается, а отправленные сообщения можно проверить.
//
// Контейнер поднимается для каждого теста (oneunit не сохраняет состояние модуля
// между &ПередВсеми и тестами). Веб-сервер стартует в фоновом задании, чтобы
// контейнер и тест жили в одном процессе и мок был доступен через НайтиЖелудь.
//
// BSLLS:DuplicateStringLiteral-off
// BSLLS:MissingVariablesDescription-off

Перем Поделка;
Перем Мессенджер;
Перем БазовыйУрл;
Перем БазовыйУрлСАвторизацией;

&ПередКаждым
Процедура ПоднятьСервер() Экспорт

	Поделка = Новый Поделка(ГенераторСоветов.СоветСДеталями());
	Поделка.ЗапуститьПриложение();

	ВебСервер = Поделка.НайтиЖелудь("ВебСервер");
	ФоновыеЗадания.Выполнить(ВебСервер, "Старт");
	Приостановить(1500);

	Мессенджер = Поделка.НайтиЖелудь("Мессенджер");

	Порт = Поделка.НайтиЖелудь("Настройки").Порт;
	БазовыйУрл = СтрШаблон("http://localhost:%1", Порт);
	БазовыйУрлСАвторизацией = СтрШаблон("http://api:s3cr3t@localhost:%1", Порт);

КонецПроцедуры

&ПослеКаждого
Процедура ОстановитьСервер() Экспорт
	Если Поделка <> Неопределено Тогда
		Поделка.НайтиЖелудь("ВебСервер").Стоп();
	КонецЕсли;
КонецПроцедуры

&Тест
Процедура ЗдоровьеОтвечает200() Экспорт
	Ответ = КоннекторHTTP.Get(БазовыйУрл + "/health");
	Ожидаем.Что(Ответ.КодСостояния).Равно(200);
КонецПроцедуры

&Тест
Процедура ОтправкаБезАвторизацииОтвечает401() Экспорт
	Тело = Новый Структура("chat_id, message", "-100500", "привет");
	Ответ = КоннекторHTTP.Post(БазовыйУрл + "/send", , Тело);
	Ожидаем.Что(Ответ.КодСостояния).Равно(401);
КонецПроцедуры

&Тест
Процедура ВалиднаяОтправкаДоходитДоМессенджера() Экспорт
	КоличествоДо = Мессенджер.ОтправленныеСообщения.Количество();

	Тело = Новый Структура("chat_id, message, format", "-1001234567890", "<b>привет</b>", "html");
	Ответ = КоннекторHTTP.Post(БазовыйУрлСАвторизацией + "/send", , Тело);

	Ожидаем.Что(Ответ.КодСостояния).Равно(200);
	Ожидаем.Что(Мессенджер.ОтправленныеСообщения.Количество()).Равно(КоличествоДо + 1);

	Последнее = Мессенджер.ОтправленныеСообщения[Мессенджер.ОтправленныеСообщения.ВГраница()];
	Ожидаем.Что(Последнее.Транспорт).Равно("telegram");
	Ожидаем.Что(Последнее.Адресат).Равно("-1001234567890");
	Ожидаем.Что(Последнее.Сообщение).Равно("<b>привет</b>");
	Ожидаем.Что(Последнее.ТипСообщения).Равно("html");
КонецПроцедуры

&Тест
Процедура НедоставкаОтвечает502() Экспорт
	// messenger 2.0.10 отдаёт Неопределено, если доставить не удалось (мок: КодОтвета = 0).
	Мессенджер.КодОтвета = 0;

	Тело = Новый Структура("chat_id, message", "-1001234567890", "привет");
	Ответ = КоннекторHTTP.Post(БазовыйУрлСАвторизацией + "/send", , Тело);

	Ожидаем.Что(Ответ.КодСостояния).Равно(502);
КонецПроцедуры

&Тест
Процедура НевалиднаяОтправкаНеДоходитДоМессенджера() Экспорт
	КоличествоДо = Мессенджер.ОтправленныеСообщения.Количество();

	Тело = Новый Структура("chat_id, message", "-100500", "");
	Ответ = КоннекторHTTP.Post(БазовыйУрлСАвторизацией + "/send", , Тело);

	// Напильник &Валидно отклоняет запрос до отправки (исключение -> 500 winow).
	Ожидаем.Что(Ответ.КодСостояния).Равно(500);
	Ожидаем.Что(Мессенджер.ОтправленныеСообщения.Количество()).Равно(КоличествоДо);
КонецПроцедуры
