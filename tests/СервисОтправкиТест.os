#Использовать ".."
#Использовать asserts

// Модульные тесты чистой логики сервиса отправки: нормализация формата и
// поведение при пустом теле. Отправка в Telegram и валидация полей здесь не
// проверяются: транспорт инициализируется контейнером, а обязательность полей
// проверяет напильник autumn-validate (см. ЗапросОтправкиТест).

// BSLLS-off: DuplicateStringLiteral

///////////////////////////////////////////////////////////////////////////////
// НормализоватьФормат
///////////////////////////////////////////////////////////////////////////////

&Тест
Процедура ФорматHtmlНормализуется() Экспорт
	Сервис = Новый СервисОтправки();
	Ожидаем.Что(Сервис.НормализоватьФормат("html")).Равно("html");
	Ожидаем.Что(Сервис.НормализоватьФормат("HTML")).Равно("html");
	Ожидаем.Что(Сервис.НормализоватьФормат("  Html  ")).Равно("html");
КонецПроцедуры

&Тест
Процедура ФорматMarkdownНормализуется() Экспорт
	Сервис = Новый СервисОтправки();
	Ожидаем.Что(Сервис.НормализоватьФормат("md")).Равно("md");
	Ожидаем.Что(Сервис.НормализоватьФормат("markdown")).Равно("md");
	Ожидаем.Что(Сервис.НормализоватьФормат("MARKDOWN")).Равно("md");
КонецПроцедуры

&Тест
Процедура НеизвестныйФорматСтановитсяПустым() Экспорт
	Сервис = Новый СервисОтправки();
	Ожидаем.Что(Сервис.НормализоватьФормат("")).Равно("");
	Ожидаем.Что(Сервис.НормализоватьФормат("text")).Равно("");
	Ожидаем.Что(Сервис.НормализоватьФормат("plain")).Равно("");
	Ожидаем.Что(Сервис.НормализоватьФормат(Неопределено)).Равно("");
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////////
// Отправить
///////////////////////////////////////////////////////////////////////////////

&Тест
Процедура ОтправитьБезТелаВозвращаетОшибку() Экспорт
	Сервис = Новый СервисОтправки();
	Результат = Сервис.Отправить(Неопределено);
	Ожидаем.Что(Результат.Успех).Равно(Ложь);
	Ожидаем.Что(Результат.КодОшибки).Равно(400);
КонецПроцедуры
