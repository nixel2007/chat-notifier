// Мок транспорта сообщений для интеграционных тестов.
//
// Реализует ту же поверхность, что использует СервисОтправки, но вместо
// обращения к Telegram запоминает параметры каждого вызова, чтобы тест мог их
// проверить.
//
// BSLLS:MissingVariablesDescription-off
// BSLLS:ExportVariables-off

// Массив структур с параметрами вызовов ОтправитьСообщение.
Перем ОтправленныеСообщения Экспорт;

// Код состояния, который вернуть из ОтправитьСообщение (по умолчанию 200).
// Значение 0 имитирует недоставку - транспорт messenger в этом случае отдаёт
// Неопределено.
Перем КодОтвета Экспорт;

// Заглушка инициализации транспорта (на случай прямого вызова).
//
// Параметры:
//   ИмяТранспорта         - Строка       - имя транспорта.
//   ПараметрыИнициализации - Структура    - параметры (игнорируются).
//
Процедура ИнициализироватьТранспорт(ИмяТранспорта, ПараметрыИнициализации = Неопределено) Экспорт
КонецПроцедуры

// Запоминает параметры отправки вместо реального обращения к Telegram и
// возвращает ответ так же, как messenger 2.0.10: объект с КодСостояния при
// успехе либо Неопределено при недоставке (КодОтвета = 0).
//
// Параметры:
//   ИмяТранспорта  - Строка - имя транспорта.
//   Адресат        - Строка - идентификатор чата.
//   Сообщение      - Строка - текст сообщения.
//   ТемаСообщения  - Строка - тема (не используется telegram).
//   ТипСообщения   - Строка - формат сообщения (parse_mode).
//
// Возвращаемое значение:
//   Структура, Неопределено - ответ с полем КодСостояния либо Неопределено.
//
Функция ОтправитьСообщение(ИмяТранспорта, Адресат, Сообщение, ТемаСообщения = "", ТипСообщения = "") Экспорт
	Вызов = Новый Структура("Транспорт, Адресат, Сообщение, ТипСообщения", ИмяТранспорта, Адресат, Сообщение, ТипСообщения);
	ОтправленныеСообщения.Добавить(Вызов);

	Если КодОтвета = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Новый Структура("КодСостояния", КодОтвета);
КонецФункции

Процедура ПриСозданииОбъекта()
	ОтправленныеСообщения = Новый Массив;
	КодОтвета = 200;
КонецПроцедуры
