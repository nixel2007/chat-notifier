#Использовать asserts
#Использовать validate

// Тесты декларативных ограничений DTO запроса. Проверяем, что аннотации
// &Заполнено на chat_id и message действительно дают нарушения валидации
// (тот же валидатор запускает напильник autumn-validate по &Валидно на
// контроллере), а заполненный запрос нарушений не имеет.

&Тест
Процедура ПустойЗапросДаетНарушения() Экспорт
	Запрос = Новый ЗапросОтправки();

	Нарушения = Новый Валидатор().Валидировать(Запрос);

	Ожидаем.Что(Нарушения.Количество() > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗапросБезИдентификатораДаетНарушение() Экспорт
	Запрос = Новый ЗапросОтправки();
	Запрос.Текст = "привет";

	Нарушения = Новый Валидатор().Валидировать(Запрос);

	Ожидаем.Что(Нарушения.Количество() > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗаполненныйЗапросБезНарушений() Экспорт
	Запрос = Новый ЗапросОтправки();
	Запрос.ИдентификаторЧата = "-1001234567890";
	Запрос.Текст = "<b>Привет</b>";
	Запрос.Формат = "html";

	Нарушения = Новый Валидатор().Валидировать(Запрос);

	Ожидаем.Что(Нарушения.Количество()).Равно(0);
КонецПроцедуры
